# --- Site ---
# Canonical origin. Used for every absolute URL the app emits (OG, JSON-LD,
# sitemap, robots, canonical links, newsletter email footers). Include
# protocol; no trailing slash. Defaults to the production domain if unset.
SITE_URL="https://agenticwithrahul.in"

# --- Newsletter / Supabase ---
# Project URL from Supabase → Settings → API. Server-only (the client
# never needs this). The Supabase client lives in lib/supabase/server.ts
# behind a `server-only` guard, so there's no reason to leak the URL into
# the browser bundle.
SUPABASE_URL="https://xxxxx.supabase.co"

# Supabase secret key (sb_secret_…) from Settings → API Keys.
# Server-only — bypasses RLS. Never expose, never prefix with NEXT_PUBLIC_.
# If you're still on the legacy service_role JWT, the server also falls back
# to SUPABASE_SERVICE_ROLE_KEY — migrate to the new format when you can.
SUPABASE_SECRET_KEY="sb_secret_..."

# Supabase publishable key (sb_publishable_…) from Settings → API Keys.
# Server-only here too — every auth flow (OAuth redirect, callback, logout)
# is routed through server handlers, so the key never reaches the browser.
# RLS-respecting: used by the cookie-aware client in lib/supabase/server.ts
# and by the proxy at proxy.ts. Falls back to SUPABASE_ANON_KEY (legacy JWT).
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Stable app-wide secret. Used as the salt when hashing subscriber IPs and
# as the key material for encrypting unsubscribe tokens. Must be stable
# across deploys — rotating it invalidates every outstanding unsubscribe
# link and breaks IP-hash comparability.
# Generate with: openssl rand -hex 32
APP_SECRET=""

# --- Newsletter / Resend (welcome email) ---
# Resend API key from https://resend.com/api-keys (server-only)
RESEND_API_KEY="re_..."

# Sender identity. The domain MUST be verified in Resend → Domains
# (SPF / DKIM / DMARC records set in DNS). Must include the display name.
NEWSLETTER_FROM_EMAIL="Rahul Gupta <newsletter@agenticwithrahul.in>"

# Where replies go. Falls back to profile.email from lib/data.ts if unset.
NEWSLETTER_REPLY_TO="notsonoobie@gmail.com"

# --- Courses / Resend (enrollment + completion emails) ---
# Sender identity for course transactional emails (enrollment confirmation,
# completion congrats). Domain MUST be verified in Resend → Domains. Must
# include the display name.
# If unset, course emails are skipped with a log line — the rest of the
# enrollment / completion flow still works without sending mail.
COURSES_FROM_EMAIL="Rahul Gupta <courses@agenticwithrahul.in>"

# Reply-to header on course emails. Optional.
#   • Set to a real inbox to route replies there (e.g., your own email).
#   • Set to a no-reply alias like "noreply@agenticwithrahul.in" if you
#     don't want users replying to course emails.
#   • Leave unset to omit the Reply-To header entirely — replies will go
#     to whatever COURSES_FROM_EMAIL points at.
COURSES_REPLY_TO=""

# --- Courses · S3 media ---
# Optional. Course cover images and episode intro videos are stored in a
# private S3 bucket and served via presigned GET URLs generated server-side
# per render. If unset, courses still render — covers fall back to the
# generated gradient tile and videos simply don't appear.
#
# IAM user attached to the bucket needs ONLY `s3:GetObject` on the bucket
# (no upload — uploads happen via AWS Console / CLI by the author).
# See docs/courses-setup.md §3a for the full setup walkthrough.
S3_REGION="ap-south-1"
S3_BUCKET="agenticwithrahul-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Status pill ---
# The footer status pill has a two-source architecture:
#
#   • Data — fetched from Better Stack Uptime API (the system actually
#     running the HTTP checks). Real-time, refreshed every 30s.
#   • Click target — opens the user's Atlassian Statuspage in a new
#     tab. Atlassian provides the public incident UI, history, and
#     subscriber management; we just don't read its data.
#
# Both env vars must be set for the pill to render. Either unset →
# pill hides cleanly (no fake "operational" placeholder).

# Public URL of the hosted Atlassian Statuspage. Used as the click
# target for the footer status pill. Visitors land on Atlassian's
# polished status page (incidents, history, subscribe).
# STATUSPAGE_URL="https://agenticwithrahul.statuspage.io"

# Better Stack Uptime API token. Server-only — used to call
# `https://uptime.betterstack.com/api/v2/monitors` for the real-time
# monitor aggregate. Generate at:
#   Better Stack → Settings → API tokens → New token
# Use the lowest-privilege scope possible (read-only is enough; the
# token only ever does GET /monitors).
# BETTERSTACK_API_TOKEN=""

# --- AI Assistant (Gemini) ---
# Powers the floating "श्रीman" widget. Used for both embeddings
# (gemini-embedding-001) and the chat model (gemini-2.5-flash).
# Generate at: https://aistudio.google.com/apikey
# Server-only. Without this, the widget hides cleanly and the
# /api/assistant/chat route returns 503.
#
# After setting, run the indexer once (also runs nightly via cron
# and on every content change via Supabase webhook — see below):
#   pnpm dlx tsx scripts/build-assistant-index.ts
# GEMINI_API_KEY=""

# --- Assistant reindex secrets ---
# Two secrets that gate /api/admin/reindex-assistant. Generate each:
#   openssl rand -hex 32

# Used by Vercel Cron's GET requests (Authorization: Bearer ...).
# Vercel auto-injects this on cron-triggered requests; you only need
# to set the env var. Schedule lives in vercel.json (daily 21:30 UTC
# = 03:00 IST).
# CRON_SECRET=""

# Used by Supabase Database Webhooks (X-Webhook-Secret header).
# Configure in Supabase Studio → Database → Webhooks → New Webhook,
# pointed at https://<your-domain>/api/admin/reindex-assistant
# with method POST and a custom header `X-Webhook-Secret: <value>`.
# Wire it up on tables: blogs, courses, episodes (Insert + Update +
# Delete events). Re-runs the indexer for just the changed source.
# REINDEX_WEBHOOK_SECRET=""

# --- Optional ---
# Google Search Console verification (DNS verification is already in place;
# only set this if you later want the meta-tag verification path too).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# --- Auto-blog (daily Gemini-authored post) ---
# Optional. When "true", the daily auto-blog cron at /api/admin/auto-blog
# inserts rows as drafts (is_published=false) instead of publishing them
# live. Useful as a kill-switch while verifying generation quality
# without removing the cron from vercel.json. Default: unset = live.
# Schedule: 02:30 UTC daily (08:00 IST). Auth: shares CRON_SECRET with
# the reindex cron above.
AUTO_BLOG_DRAFT=""

# Flip to "false" to render the Hero/Contact availability badge as
# "open for consultations" instead of "available".
NEXT_PUBLIC_OPEN_TO_WORK="false"
